{
  "info": {
    "name": "CareerCraft API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "CareerCraft Backend API — Auth + AI + Jobs + Admin"
  },
  "variable": [
    { "key": "base_url", "value": "https://careercraft-app-production.up.railway.app/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"type\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"type\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/user/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/user/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/user/profile",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}"
            }
          }
        },
        {
          "name": "Get Skills",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/user/skills",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Dashboard",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/user/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Report",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/user/report",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "AI Status (Public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/ai/status"
          }
        },
        {
          "name": "Career Recommendations",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/ai/career-recommendations",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Job Match",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/ai/job-match/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "AI Advice",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/ai/advice",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"How can I grow as a backend developer?\"\n}"
            }
          }
        },
        {
          "name": "Suggested Skills",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/ai/suggested-skills?career_path=Backend%20Developer",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Resume Review",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/ai/resume-review",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resume_text\": \"Your resume content here...\"\n}"
            }
          }
        },
        {
          "name": "Interview Simulate",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/ai/interview-simulate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_id\": 1,\n  \"job_title\": \"Backend Developer\",\n  \"job_context\": \"Laravel, APIs, MySQL\",\n  \"conversation\": []\n}"
            }
          }
        },
        {
          "name": "Chatbot",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/ai/chatbot",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"What skills should I learn for backend development?\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "List Jobs (Public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs"
          }
        },
        {
          "name": "Get Job Details (Public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs/1"
          }
        },
        {
          "name": "Apply to Job",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/applications",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_id\": 1\n}"
            }
          }
        },
        {
          "name": "My Applications",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/applications",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Company",
      "item": [
        {
          "name": "Get Company Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/company/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Post Job",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/jobs",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Backend Developer\",\n  \"description\": \"We are looking for a Laravel engineer.\",\n  \"location\": \"Remote\",\n  \"skills\": [\n    { \"skill_id\": 1, \"required_level\": \"intermediate\" }\n  ]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Backend Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    }
  ]
}
